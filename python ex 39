# Create empty stack
stack = []

# Push operation
stack.append(10)
stack.append(20)
stack.append(30)

print("Stack after push:", stack)

# Pop operation
removed = stack.pop()
print("Removed element:", removed)

print("Stack after pop:", stack)

# Peek operation
top = stack[-1]
print("Top element:", top)

# Check if empty
if len(stack) == 0:
    print("Stack is empty")
else:
    print("Stack is not empty")